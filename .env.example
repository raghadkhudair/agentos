# Runtime
AGENTOS_PROJECT_NAME=ecommerce-demo
AGENTOS_WORKSPACE=/workspace
AGENTOS_ENV=local
AGENTOS_LOG_LEVEL=INFO

# Ray
RAY_ADDRESS=ray://ray-head:10001
AGENTOS_MAX_AGENTS_TOTAL=20
AGENTOS_MAX_ACTIVE_AGENTS=12
AGENTOS_MAX_PARALLEL_CODE_TASKS=8

# PostgreSQL + pgvector
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agentos
POSTGRES_USER=agentos
POSTGRES_PASSWORD=agentos
DATABASE_URL=postgresql://agentos:agentos@postgres:5432/agentos

# Dragonfly / Redis-compatible coordination layer
DRAGONFLY_URL=redis://dragonfly:6379/0

# External AI provider through LiteLLM
# Example values only. Store real keys locally and never commit them.
AGENTOS_PROVIDER_DEFAULT_MODEL=openai/gpt-4.1
AGENTOS_PROVIDER_FALLBACK_MODEL=openai/gpt-4.1-mini
AGENTOS_EMBEDDING_MODEL=openai/text-embedding-3-small
AGENTOS_EMBEDDING_DIMENSION=1536
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Budgets
AGENTOS_DAILY_BUDGET_USD=100
AGENTOS_MONTHLY_BUDGET_USD=1000

# Safety
AGENTOS_REQUIRE_REVIEW=true
AGENTOS_REQUIRE_TESTS=true
AGENTOS_REQUIRE_HUMAN_APPROVAL_FOR_CRITICAL=true
AGENTOS_ALLOW_DESTRUCTIVE_ACTIONS=false
