# Copy to .env and replace every CHANGE_ME value. Never commit .env.
AGENTOS_ENV=production
AGENTOS_PROJECT_NAME=agentos-project
AGENTOS_REQUEST=Build the requested software project with tests and documentation.
AGENTOS_WORKSPACE=/workspaces
# Optional Git worktree path visible inside the AgentOS runtime process.
AGENTOS_SOURCE_REPOSITORY=
AGENTOS_LOG_LEVEL=INFO

# Host resource ceiling. AgentOS always leaves at least one detected core unused.
AGENTOS_CPU_USAGE_FRACTION=0.70
AGENTOS_RESERVED_CPU_CORES=1
AGENTOS_MAX_CPU_CORES=4
AGENTOS_MEMORY_USAGE_FRACTION=0.70
AGENTOS_RESERVED_MEMORY_BYTES=1073741824
AGENTOS_MAX_MEMORY_BYTES=4294967296
AGENTOS_OBJECT_STORE_MEMORY_BYTES=268435456
AGENTOS_WORKER_CPU=0.5
AGENTOS_WORKER_MEMORY_BYTES=536870912
AGENTOS_MAX_AGENTS_TOTAL=20
AGENTOS_MAX_ACTIVE_AGENTS=8
AGENTOS_MAX_PARALLEL_CODE_TASKS=4
AGENTOS_MAX_THREADS_PER_AGENT=2
AGENTOS_COLLABORATION_INTERVAL_SECONDS=30

# PostgreSQL durable source of truth
POSTGRES_DB=agentos
POSTGRES_USER=agentos
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD
DATABASE_URL=postgresql://agentos:CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD@postgres:5432/agentos
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=2
POSTGRES_CONNECTION_BUDGET=100
AGENTOS_POSTGRES_HOST_PORT=55432

# Dragonfly hot coordination
DRAGONFLY_PASSWORD=CHANGE_ME_LONG_RANDOM_DRAGONFLY_PASSWORD
DRAGONFLY_URL=redis://:CHANGE_ME_LONG_RANDOM_DRAGONFLY_PASSWORD@dragonfly:6379/0
AGENTOS_DRAGONFLY_HOST_PORT=56380

# MongoDB mid-term memory
MONGO_INITDB_ROOT_USERNAME=agentos
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_MONGODB_PASSWORD
MONGODB_URL=mongodb://agentos:CHANGE_ME_LONG_RANDOM_MONGODB_PASSWORD@mongodb:27017/agentos?authSource=admin
MONGODB_DATABASE=agentos
AGENTOS_MIDTERM_MEMORY_TTL_SECONDS=604800
AGENTOS_MONGODB_HOST_PORT=57017

# Milvus semantic index
MILVUS_URI=http://milvus:19530
MILVUS_DATABASE=default
MILVUS_COLLECTION_PREFIX=agentos
MILVUS_TOKEN=
AGENTOS_EMBEDDING_DIMENSION=1536
AGENTOS_EMBEDDING_MODEL=openai/text-embedding-3-small

# MinIO object storage
MINIO_ROOT_USER=agentosminio
MINIO_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=agentosminio
MINIO_SECRET_KEY=CHANGE_ME_LONG_RANDOM_MINIO_PASSWORD
MINIO_SECURE=false
MINIO_ARTIFACTS_BUCKET=agentos-artifacts
MINIO_MEMORY_BUCKET=agentos-memory
AGENTOS_MINIO_API_HOST_PORT=59000
AGENTOS_MINIO_CONSOLE_HOST_PORT=59001

# AI providers. Configure one or more real credentials; keys are read by LiteLLM.
OPENAI_API_KEY=
OPENAI_API_BASE=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
GEMINI_API_KEY=
GEMINI_API_BASE=
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=
MOONSHOT_API_KEY=
MOONSHOT_API_BASE=
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=
ZAI_API_KEY=
ZAI_API_BASE=
MINIMAX_API_KEY=
MINIMAX_API_BASE=
OLLAMA_API_BASE=
# Optional per-complexity overrides use PROVIDER_MODEL_LOW, _STANDARD, _HIGH,
# and _CRITICAL; for example OPENAI_MODEL_HIGH=openai/gpt-5.1.
AGENTOS_PROVIDER_DEFAULT=openai
AGENTOS_PROVIDER_MAX_ATTEMPTS=3
AGENTOS_PROVIDER_TIMEOUT_SECONDS=120
AGENTOS_PROVIDER_MAX_CONCURRENCY=8
AGENTOS_PROVIDER_CALL_RESERVATION_USD=1.00
AGENTOS_PROVIDER_UNKNOWN_COST_CHARGE_USD=1.00
AGENTOS_DAILY_BUDGET_USD=100
AGENTOS_MONTHLY_BUDGET_USD=1000

# Guardrails and sandbox
AGENTOS_REQUIRE_REVIEW=true
AGENTOS_REQUIRE_TESTS=true
AGENTOS_REQUIRE_HUMAN_APPROVAL_FOR_CRITICAL=true
AGENTOS_ALLOW_DESTRUCTIVE_ACTIONS=false
SANDBOX_DATABASE_URL=postgresql://agentos_sandbox:CHANGE_ME_SANDBOX_PASSWORD@sandbox-postgres:5432/agentos_sandbox
SANDBOX_POSTGRES_PASSWORD=CHANGE_ME_SANDBOX_PASSWORD
DOCKER_HOST=tcp://docker-proxy:2375
AGENTOS_SANDBOX_IMAGE=python:3.12.11-slim-bookworm
AGENTOS_SANDBOX_WORKSPACE_VOLUME=agentos_workspaces
AGENTOS_SANDBOX_CPU_LIMIT=1
AGENTOS_SANDBOX_MEMORY_BYTES=1073741824

# Compose container ceilings
AGENTOS_CONTAINER_CPUS=4.0
AGENTOS_CONTAINER_MEMORY=6g
AGENTOS_SHM_SIZE=512m
